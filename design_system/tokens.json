{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "project": "NaaPeru",
    "description": "Design tokens for NaaPeru portfolio — Kedhar, AI Engineer + Developer",
    "generated": "2026-03-10",
    "source": "src/index.css + tailwind.config.ts + design_system/brand-tokens.css"
  },

  "color": {
    "$type": "color",

    "brand": {
      "$description": "Crimson red ramp extracted from logo mark (hsl(5,78%,42%) = #C0261A)",
      "50":  { "$value": "hsl(5, 74%, 97%)",  "$description": "Lightest tint" },
      "100": { "$value": "hsl(5, 72%, 93%)",  "$description": "Very light tint" },
      "200": { "$value": "hsl(5, 68%, 86%)",  "$description": "Light tint" },
      "300": { "$value": "hsl(5, 64%, 74%)",  "$description": "Medium-light" },
      "400": { "$value": "hsl(5, 59%, 60%)",  "$description": "Medium" },
      "500": { "$value": "hsl(5, 78%, 42%)",  "$description": "Logo red — authoritative brand color (#C0261A)" },
      "600": { "$value": "hsl(5, 82%, 36%)",  "$description": "Medium-dark" },
      "700": { "$value": "hsl(5, 84%, 30%)",  "$description": "Dark" },
      "800": { "$value": "hsl(5, 86%, 24%)",  "$description": "Very dark" },
      "900": { "$value": "hsl(5, 89%, 17%)",  "$description": "Darkest" },
      "950": { "$value": "hsl(5, 92%, 10%)",  "$description": "Near-black" }
    },

    "neutral": {
      "$description": "Blue-gray ramp — matches existing dark-mode surfaces",
      "50":  { "$value": "hsl(220,  8%, 97%)", "$description": "#F5F6F9" },
      "100": { "$value": "hsl(220,  8%, 93%)", "$description": "#ECEEF3" },
      "200": { "$value": "hsl(220,  8%, 85%)", "$description": "#D4D8E3" },
      "300": { "$value": "hsl(220,  8%, 72%)", "$description": "#B0B6C8" },
      "400": { "$value": "hsl(220,  8%, 55%)", "$description": "#848DAA" },
      "500": { "$value": "hsl(220,  8%, 40%)", "$description": "#5E677E" },
      "600": { "$value": "hsl(220, 10%, 28%)", "$description": "#404A60" },
      "700": { "$value": "hsl(220, 14%, 20%)", "$description": "#2C3449" },
      "800": { "$value": "hsl(220, 20%, 14%)", "$description": "#1D2230 — surface-elevated" },
      "900": { "$value": "hsl(220, 22%, 10%)", "$description": "#151922 — surface-subtle" },
      "950": { "$value": "hsl(220, 26%,  7%)", "$description": "#0E1017 — page background" }
    },

    "semantic": {
      "$description": "Purpose-mapped tokens — wired to Tailwind via CSS variables",
      "background":           { "$value": "{color.neutral.950}", "$description": "Page background" },
      "foreground":           { "$value": "#ffffff",             "$description": "Primary text" },
      "surface-subtle":       { "$value": "{color.neutral.900}", "$description": "Hover areas, subtle panels" },
      "surface-elevated":     { "$value": "{color.neutral.800}", "$description": "Cards, panels, chatbot" },
      "card":                 { "$value": "{color.neutral.950}", "$description": "Card base (same as bg, use with opacity)" },
      "primary":              { "$value": "hsl(0, 100%, 50%)",   "$description": "#FF0000 — display-weight brand red (CSS primary)" },
      "primary-hover":        { "$value": "hsl(0, 100%, 45%)",   "$description": "#E60000 — hover state" },
      "muted":                { "$value": "hsl(0, 0%, 20%)",     "$description": "#333333 — muted surfaces" },
      "muted-foreground":     { "$value": "hsl(0, 0%, 54%)",     "$description": "#8A8A8A — de-emphasized text" },
      "border":               { "$value": "hsl(0, 0%, 20%)",     "$description": "#333333 — dividers" },
      "ring":                 { "$value": "hsl(0, 100%, 50%)",   "$description": "#FF0000 — focus ring" },
      "destructive":          { "$value": "hsl(0, 84.2%, 60.2%)", "$description": "#EF4444 — error states" }
    },

    "status": {
      "success":  { "$value": "hsl(158, 64%, 38%)", "$description": "#22A06B" },
      "warning":  { "$value": "hsl(38,  92%, 50%)", "$description": "#F59E0B" },
      "error":    { "$value": "hsl(0,   84%, 60%)", "$description": "#EF4444" },
      "info":     { "$value": "hsl(213, 94%, 68%)", "$description": "#60A5FA" }
    }
  },

  "spacing": {
    "$type": "dimension",
    "$description": "8px base grid",
    "0":   { "$value": "0px" },
    "px":  { "$value": "1px" },
    "0.5": { "$value": "2px" },
    "1":   { "$value": "4px" },
    "1.5": { "$value": "6px" },
    "2":   { "$value": "8px",   "$description": "xs" },
    "3":   { "$value": "12px" },
    "4":   { "$value": "16px",  "$description": "sm" },
    "5":   { "$value": "20px" },
    "6":   { "$value": "24px",  "$description": "md — card padding" },
    "8":   { "$value": "32px",  "$description": "lg" },
    "10":  { "$value": "40px" },
    "12":  { "$value": "48px",  "$description": "xl" },
    "16":  { "$value": "64px",  "$description": "2xl" },
    "20":  { "$value": "80px",  "$description": "section padding" },
    "24":  { "$value": "96px",  "$description": "3xl" },
    "32":  { "$value": "128px", "$description": "4xl — hero padding" }
  },

  "typography": {
    "fontFamily": {
      "$type": "fontFamily",
      "heading":  { "$value": ["Space Grotesk", "sans-serif"], "$description": "font-heading — all headings" },
      "body":     { "$value": ["Inter", "sans-serif"],         "$description": "font-body — paragraphs, meta, labels" },
      "sanchari": { "$value": ["DhurjatiItalic", "Space Grotesk", "sans-serif"], "$description": "font-sanchari — సంచారి? only" }
    },
    "fontWeight": {
      "$type": "fontWeight",
      "light":    { "$value": 300 },
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    },
    "fontSize": {
      "$type": "dimension",
      "2xs":  { "$value": "0.625rem",  "$description": "10px — micro labels" },
      "xs":   { "$value": "0.75rem",   "$description": "12px" },
      "sm":   { "$value": "0.875rem",  "$description": "14px" },
      "base": { "$value": "1rem",      "$description": "16px" },
      "lg":   { "$value": "1.125rem",  "$description": "18px" },
      "xl":   { "$value": "1.25rem",   "$description": "20px" },
      "2xl":  { "$value": "1.5rem",    "$description": "24px" },
      "3xl":  { "$value": "1.875rem",  "$description": "30px" },
      "4xl":  { "$value": "2.25rem",   "$description": "36px" },
      "5xl":  { "$value": "3rem",      "$description": "48px" },
      "6xl":  { "$value": "3.75rem",   "$description": "60px" },
      "7xl":  { "$value": "4.5rem",    "$description": "72px" },
      "8xl":  { "$value": "6rem",      "$description": "96px — hero" }
    },
    "letterSpacing": {
      "$type": "dimension",
      "tight":   { "$value": "-0.02em" },
      "normal":  { "$value": "0" },
      "wide":    { "$value": "0.08em" },
      "wider":   { "$value": "0.12em",  "$description": "nav items" },
      "widest":  { "$value": "0.35em",  "$description": "micro labels" }
    }
  },

  "shadow": {
    "$type": "shadow",
    "sm":   { "$value": "0 2px 8px rgba(0,0,0,0.40)" },
    "md":   { "$value": "0 8px 32px rgba(0,0,0,0.60)" },
    "lg":   { "$value": "0 16px 48px rgba(0,0,0,0.80)" },
    "glow": { "$value": "0 0 40px rgba(255,0,0,0.30)", "$description": "Red glow — hero, circular badge" }
  },

  "motion": {
    "duration": {
      "$type": "duration",
      "fast":   { "$value": "150ms" },
      "normal": { "$value": "300ms" },
      "slow":   { "$value": "500ms" },
      "slower": { "$value": "800ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "smooth":    { "$value": [0.4, 0.0, 0.2, 1],      "$description": "ease-smooth — most transitions" },
      "bounce":    { "$value": [0.68, -0.55, 0.265, 1.55], "$description": "ease-bounce — playful interactions" },
      "confident": { "$value": [0.25, 0.46, 0.45, 0.94], "$description": "ease-confident — slide-up, scale-in" }
    },
    "animation": {
      "$type": "custom",
      "fade-in":    { "$value": "fade-in 0.3s ease-out",            "$description": "Nav items, chatbot" },
      "slide-up":   { "$value": "slide-up 0.8s confident forwards", "$description": "Hero headline, copy" },
      "scale-in":   { "$value": "scale-in 0.5s confident forwards", "$description": "Badges, overlays" },
      "glow-pulse": { "$value": "glow-pulse 2s ease-in-out infinite","$description": "సంచారి? button" },
      "float":      { "$value": "float 3s ease-in-out infinite",     "$description": "Hero glow blob" },
      "ticker":     { "$value": "ticker 55s linear infinite",        "$description": "Hero strip" },
      "progress":   { "$value": "progress 2.5s confident forwards",  "$description": "Loading bar" }
    }
  },

  "borderRadius": {
    "$type": "dimension",
    "none": { "$value": "0",       "$description": "Cards, panels — design rule" },
    "sm":   { "$value": "2px" },
    "md":   { "$value": "2px" },
    "lg":   { "$value": "4px",     "$description": "--radius — nav dropdown, shadcn components" },
    "full": { "$value": "9999px",  "$description": "Circular elements, pills" }
  },

  "component": {
    "card": {
      "background":       { "$value": "hsl(220 26% 7% / 0.4)" },
      "border":           { "$value": "hsl(0 0% 20% / 0.25)" },
      "hoverBackground":  { "$value": "hsl(220 26% 7% / 0.6)" },
      "hoverBorder":      { "$value": "hsl(0 100% 50% / 0.4)" },
      "padding":          { "$value": "{spacing.6}" },
      "borderRadius":     { "$value": "{borderRadius.none}" }
    },
    "button": {
      "primary": {
        "background":   { "$value": "{color.semantic.primary}" },
        "foreground":   { "$value": "{color.semantic.background}" },
        "hoverBg":      { "$value": "{color.semantic.primary-hover}" },
        "paddingX":     { "$value": "{spacing.6}" },
        "paddingY":     { "$value": "{spacing.3}" },
        "fontSize":     { "$value": "{typography.fontSize.sm}" },
        "fontWeight":   { "$value": "{typography.fontWeight.bold}" },
        "letterSpacing":{ "$value": "0.3em" },
        "borderRadius": { "$value": "{borderRadius.none}" }
      },
      "ghost": {
        "background":   { "$value": "transparent" },
        "foreground":   { "$value": "{color.semantic.foreground}" },
        "border":       { "$value": "hsl(0 0% 20% / 0.25)" },
        "hoverBorder":  { "$value": "{color.semantic.primary}" },
        "hoverFg":      { "$value": "{color.semantic.primary}" },
        "paddingX":     { "$value": "{spacing.6}" },
        "paddingY":     { "$value": "{spacing.3}" },
        "borderRadius": { "$value": "{borderRadius.none}" }
      }
    },
    "navigation": {
      "heightDefault":        { "$value": "96px" },
      "heightCompact":        { "$value": "80px" },
      "scrollThreshold":      { "$value": "100px" },
      "mobileBreakpoint":     { "$value": "768px" },
      "dropdownWidth":        { "$value": "224px" },
      "dropdownBackground":   { "$value": "hsl(220 26% 7% / 0.95)" },
      "dropdownBorder":       { "$value": "hsl(0 0% 20% / 0.20)" }
    },
    "input": {
      "height":          { "$value": "40px" },
      "paddingX":        { "$value": "12px" },
      "background":      { "$value": "{color.neutral.900}" },
      "border":          { "$value": "rgba(255,255,255,0.20)" },
      "borderFocus":     { "$value": "{color.semantic.ring}" },
      "placeholder":     { "$value": "rgba(255,255,255,0.30)" }
    },
    "tag": {
      "paddingX":      { "$value": "8px" },
      "paddingY":      { "$value": "4px" },
      "fontSize":      { "$value": "{typography.fontSize.xs}" },
      "letterSpacing": { "$value": "0.08em" },
      "background":    { "$value": "rgba(255,255,255,0.07)" },
      "border":        { "$value": "rgba(255,255,255,0.10)" },
      "foreground":    { "$value": "rgba(255,255,255,0.50)" }
    },
    "footer": {
      "padding":     { "$value": "32px 0" },
      "borderTop":   { "$value": "1px solid hsl(0 0% 20% / 0.10)" },
      "background":  { "$value": "{color.semantic.background}" }
    },
    "chatbot": {
      "panelWidth":    { "$value": "384px" },
      "background":    { "$value": "{color.neutral.800}" },
      "border":        { "$value": "hsl(0 0% 20% / 0.40)" },
      "maxInputLength":{ "$value": "500" }
    },
    "sectionLabel": {
      "fontSize":      { "$value": "{typography.fontSize.xs}" },
      "letterSpacing": { "$value": "{typography.letterSpacing.widest}" },
      "color":         { "$value": "hsl(0 100% 50% / 0.70)" },
      "fontFamily":    { "$value": "{typography.fontFamily.body}" },
      "textTransform": { "$value": "uppercase" }
    },
    "ticker": {
      "background": { "$value": "hsl(1, 90%, 24%)" },
      "duration":   { "$value": "55s" },
      "rotation": {
        "sm": { "$value": "-1deg" },
        "lg": { "$value": "-3deg" }
      }
    }
  },

  "layout": {
    "container": {
      "maxWidth": { "$value": "1440px" },
      "padding": {
        "default": { "$value": "24px",  "$description": "px-6 mobile" },
        "sm":      { "$value": "32px",  "$description": "px-8 sm" },
        "md":      { "$value": "48px",  "$description": "px-12 md" },
        "lg":      { "$value": "64px",  "$description": "px-16 lg" },
        "xl":      { "$value": "80px",  "$description": "px-20 xl" }
      }
    },
    "grid": {
      "columns": {
        "mobile": { "$value": 4 },
        "md":     { "$value": 8 },
        "lg":     { "$value": 12 }
      },
      "gap": {
        "mobile": { "$value": "16px" },
        "md":     { "$value": "24px" },
        "lg":     { "$value": "32px" }
      }
    },
    "breakpoints": {
      "sm": { "$value": "640px" },
      "md": { "$value": "768px" },
      "lg": { "$value": "1024px" },
      "xl": { "$value": "1280px" }
    }
  }
}
